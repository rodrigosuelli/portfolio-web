{
  /**
   * Using vscode workspace TypeScript version is required for the TypeScript plugin typescript-plugin-css-modules to work.
   * The typescript.tsdk workspace setting only tells VS Code that a workspace version of TypeScript exists.
   * To actually start using the workspace version for IntelliSense, you must run the TypeScript: Select TypeScript Version command and select the workspace version.
   */
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  // viijay-kr.react-ts-css vscode extension settings
  "reactTsScss.autoComplete": true,
  "reactTsScss.definition": true,
  "reactTsScss.peekProperties": true,
  "reactTsScss.cssAutoComplete": true,
  "reactTsScss.cssDefinitions": true,
  "reactTsScss.diagnostics": true,
  "reactTsScss.baseDir": "src",
  "reactTsScss.cssSyntaxColor": true,
  "reactTsScss.tsCleanUpDefs": true,
  "reactTsScss.cleanUpDefs": [
    "*.module.css",
    "*.module.scss",
    "*.module.sass",
    "*.module.less",
    "*.module.styl"
  ],
  "reactTsScss.references": true,
  "reactTsScss.codelens": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.removeUnusedImports": "explicit",
    "source.sortImports": "explicit",
    "source.organizeImports": "explicit",
    "source.organizeLinkDefinitions": "explicit"
  },
  "material-icon-theme.activeIconPack": "react", // material-icon-theme
}
